# Copy to .env and fill in. .env is gitignored (never commit secrets).

# --- Warehouse (OMOP CDM lives here) ---------------------------------------
WAREHOUSE_DB=data/omop.duckdb

# --- FHIR server (HAPI FHIR via Docker) ------------------------------------
FHIR_BASE_URL=http://localhost:8080/fhir

# --- API security (optional — empty = no auth, demo mode) ------------------
API_KEY=
RATE_LIMIT_PER_MINUTE=0          # 0 = disabled

# --- LLM provider (anthropic | openai) -------------------------------------
LLM_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (only used if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# Optional: custom base URL for local / proxy endpoints
LLM_BASE_URL=

# --- Database engine -------------------------------------------------------
# duckdb = zero-cost local demo (default)
# postgres = production PostgreSQL (requires psycopg driver)
DB_ENGINE=duckdb
POSTGRES_DSN=postgresql://user:pass@localhost:5432/omop

# --- Observability (logging) -----------------------------------------------
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=text                      # text (dev) | json (prod)
